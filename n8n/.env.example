# Copy to n8n/.env and fill in (values are in config.yml).
# docker compose reads this automatically; never commit the real .env.
GENERIC_TIMEZONE=Europe/Zurich

# anthropic.api_key in config.yml
ANTHROPIC_API_KEY=

# fal.api_key in config.yml
FAL_API_KEY=

# tiktok.client_key / tiktok.client_secret in config.yml
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
